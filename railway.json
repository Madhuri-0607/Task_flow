{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --worker-class sync --worker-connections 1000 --timeout 120 --access-logfile - --error-logfile - --log-level info",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "plugins": [
    "postgresql"
  ]
}
